{
  "name": "perfect-ui-workspace",
  "version": "3.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve demo",
    "build": "ng build",
    "build:perfectui": "ng build perfectui --configuration production",
    "build:demo": "npm run build:perfectui && ng build demo --base-href /perfect-ui/ --configuration production",
    "build:all": "npm run build:perfectui && npm run build:demo",
    "watch": "ng build perfectui --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint || true",
    "publish:perfectui": "npm run build:perfectui && cd dist/perfectui && npm publish --access public",
    "release": "standard-version",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:first": "standard-version --first-release",
    "release:dry": "standard-version --dry-run",
    "prepare": "husky || true"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.1.0",
    "@angular/build": "^21.1.0",
    "@angular/cli": "^21.1.0",
    "@angular/compiler-cli": "^21.1.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "husky": "^9.0.0",
    "jsdom": "^27.4.0",
    "ng-packagr": "^21.1.0",
    "standard-version": "^9.5.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.17"
  }
}
